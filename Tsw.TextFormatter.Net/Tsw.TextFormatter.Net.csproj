<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Title>Tsw.TextFormatter.Net</Title>
    <Version>1.1.0</Version>
    <Authors>Tomasz Więzik</Authors>
    <Description>Plain text formatter.</Description>
    <Copyright>Copyright (C) Tomasz Więzik</Copyright>
    <PackageProjectUrl>https://github.com/tomaszwiezik/Tsw.TextFormatter.Net</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>command-line;text;plain-text;table</PackageTags>
    <PackageReleaseNotes>Column formatting extended with ForceWidth attribute.</PackageReleaseNotes>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
